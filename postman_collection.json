{
  "info": {
    "name": "Property Maintenance API",
    "description": "API tests for TENANT, MANAGER, TECHNICIAN, ADMIN roles with image upload",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000/api/v1", "type": "string" },
    { "key": "tenantEmail", "value": "tenant@test.com", "type": "string" },
    { "key": "managerEmail", "value": "manager@test.com", "type": "string" },
    { "key": "technicianEmail", "value": "technician@test.com", "type": "string" },
    { "key": "adminEmail", "value": "admin@test.com", "type": "string" },
    { "key": "password", "value": "password123", "type": "string" },
    { "key": "tenantId", "value": "", "type": "string" },
    { "key": "managerId", "value": "", "type": "string" },
    { "key": "propertyId", "value": "", "type": "string" },
    { "key": "ticketId", "value": "", "type": "string" }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (pm.response.status === 200 || pm.response.status === 201) {",
          "    var jsonData = pm.response.json();",
          "    if (jsonData.accessToken) pm.collectionVariables.set('accessToken', jsonData.accessToken);",
          "    if (jsonData.user && jsonData.user.id) {",
          "        if (jsonData.user.role === 'TENANT') pm.collectionVariables.set('tenantId', jsonData.user.id);",
          "        if (jsonData.user.role === 'MANAGER') pm.collectionVariables.set('managerId', jsonData.user.id);",
          "    }",
          "    if (jsonData.property && jsonData.property.id) pm.collectionVariables.set('propertyId', jsonData.property.id);",
          "    if (jsonData.ticket && jsonData.ticket.id) pm.collectionVariables.set('ticketId', jsonData.ticket.id);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "AUTH",
      "item": [
        {
          "name": "Register TENANT",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"name\":\"Tenant User\",\"email\":\"{{tenantEmail}}\",\"password\":\"{{password}}\",\"phone\":\"1111111111\",\"role\":\"TENANT\"}" }
          }
        },
        {
          "name": "Register MANAGER",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"name\":\"Manager User\",\"email\":\"{{managerEmail}}\",\"password\":\"{{password}}\",\"phone\":\"2222222222\",\"role\":\"MANAGER\"}" }
          }
        },
        {
          "name": "Register TECHNICIAN",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"name\":\"Technician User\",\"email\":\"{{technicianEmail}}\",\"password\":\"{{password}}\",\"phone\":\"3333333333\",\"role\":\"TECHNICIAN\"}" }
          }
        },
        {
          "name": "Register ADMIN",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"name\":\"Admin User\",\"email\":\"{{adminEmail}}\",\"password\":\"{{password}}\",\"phone\":\"4444444444\",\"role\":\"ADMIN\"}" }
          }
        },
        {
          "name": "Login TENANT",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"{{tenantEmail}}\",\"password\":\"{{password}}\"}" }
          }
        },
        {
          "name": "Login MANAGER",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"{{managerEmail}}\",\"password\":\"{{password}}\"}" }
          }
        },
        {
          "name": "Login ADMIN",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"{{adminEmail}}\",\"password\":\"{{password}}\"}" }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }]
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users/auth/logout",
            "header": [{ "key": "Content-Type", "value": "application/json" }]
          }
        }
      ]
    },
    {
      "name": "TENANT",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/auth/me",
            "header": [{ "key": "Content-Type", "value": "application/json" }]
          }
        },
        {
          "name": "Create Ticket (No Images)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tickets/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"title\":\"Leaky faucet\",\"description\":\"Bathroom sink is leaking water\",\"priority\":\"MEDIUM\",\"propertyId\":\"{{propertyId}}\",\"unit\":\"101\"}" }
          }
        },
        {
          "name": "Create Ticket (With Images)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tickets/",
            "header": [{ "key": "Content-Type", "value": "multipart/form-data" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Broken door lock", "type": "text" },
                { "key": "description", "value": "The door lock is broken and won't open", "type": "text" },
                { "key": "priority", "value": "HIGH", "type": "text" },
                { "key": "propertyId", "value": "{{propertyId}}", "type": "text" },
                { "key": "unit", "value": "101", "type": "text" },
                { "key": "images", "type": "file", "src": [] }
              ]
            }
          }
        },
        {
          "name": "Create Ticket with Image URLs",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tickets/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"title\":\"Electrical issue\",\"description\":\"Power outlet not working in kitchen\",\"priority\":\"URGENT\",\"propertyId\":\"{{propertyId}}\",\"unit\":\"102\",\"imageUrls\":[\"https://example.com/image1.jpg\"]}" }
          }
        },
        {
          "name": "Get My Tickets",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tickets/my",
            "header": [{ "key": "Content-Type", "value": "application/json" }]
          }
        },
        {
          "name": "Try Access All Users (Should Fail 403)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }]
          }
        },
        {
          "name": "Try Create Property (Should Fail 403)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/properties/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"name\":\"Test Property\",\"address\":\"123 Test St\",\"type\":\"APARTMENT\"}" }
          }
        }
      ]
    },
    {
      "name": "MANAGER",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }]
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/users/{{tenantId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }]
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/users/{{tenantId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"name\":\"Updated Tenant Name\"}" }
          }
        },
        {
          "name": "Create Property",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/properties/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"name\":\"Sunset Apartments\",\"address\":\"123 Sunset Blvd, Los Angeles, CA 90028\",\"type\":\"APARTMENT\",\"totalUnits\":20}" }
          }
        },
        {
          "name": "Get All Properties",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/properties/",
            "header": [{ "key": "Content-Type", "value": "application/json" }]
          }
        },
        {
          "name": "Get Property By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/properties/{{propertyId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }]
          }
        },
        {
          "name": "Try Assign Manager (Should Fail 403)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/properties/{{propertyId}}/assign-manager",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"managerId\":\"{{managerId}}\"}" }
          }
        }
      ]
    },
    {
      "name": "ADMIN",
      "item": [
        {
          "name": "Assign Manager to Property",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/properties/{{propertyId}}/assign-manager",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"managerId\":\"{{managerId}}\"}" }
          }
        }
      ]
    },
    {
      "name": "PUBLIC",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "header": []
          }
        },
        {
          "name": "Root API",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/",
            "header": []
          }
        }
      ]
    },
    {
      "name": "NEGATIVE TESTS",
      "item": [
        {
          "name": "Login Invalid Credentials",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"wrong@test.com\",\"password\":\"wrongpass\"}" }
          }
        },
        {
          "name": "Register Duplicate Email",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"name\":\"Duplicate\",\"email\":\"{{tenantEmail}}\",\"password\":\"{{password}}\",\"phone\":\"9999999999\",\"role\":\"TENANT\"}" }
          }
        },
        {
          "name": "Access Without Token",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/auth/me",
            "header": []
          }
        },
        {
          "name": "Create Ticket Without Property (Should Fail)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tickets/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"title\":\"Test\",\"description\":\"Test description\"}" }
          }
        },
        {
          "name": "Upload Non-Image File (Should Fail)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tickets/",
            "header": [{ "key": "Content-Type", "value": "multipart/form-data" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Test", "type": "text" },
                { "key": "description", "value": "Test", "type": "text" },
                { "key": "propertyId", "value": "{{propertyId}}", "type": "text" },
                { "key": "images", "value": "test.txt", "type": "file", "src": [] }
              ]
            }
          }
        }
      ]
    }
  ]
}
