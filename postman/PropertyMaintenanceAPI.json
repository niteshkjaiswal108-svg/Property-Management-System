{
  "info": {
    "name": "Property Maintenance API",
    "description": "API for property maintenance management system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "managerUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "tenantUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "technicianUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "propertyId",
      "value": "",
      "type": "string"
    },
    {
      "key": "unitId",
      "value": "",
      "type": "string"
    },
    {
      "key": "ticketId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/"
          }
        },
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "API Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register - ADMIN",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/users/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"ADMIN\"\n}"
            }
          }
        },
        {
          "name": "Register - MANAGER",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/users/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Manager User\",\n  \"email\": \"manager@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"MANAGER\"\n}"
            }
          }
        },
        {
          "name": "Register - TENANT",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/users/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tenant User\",\n  \"email\": \"tenant@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"TENANT\"\n}"
            }
          }
        },
        {
          "name": "Register - TECHNICIAN",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/users/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Technician User\",\n  \"email\": \"tech@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"TECHNICIAN\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/users/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.data?.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
                  "}",
                  "if (jsonData.data?.refreshToken) {",
                  "    pm.collectionVariables.set('refreshToken', jsonData.data.refreshToken);",
                  "}",
                  "if (jsonData.data?.user?.id) {",
                  "    pm.collectionVariables.set('userId', jsonData.data.user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/users/auth/refresh",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/users/auth/logout",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Users (Admin/Manager only)",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/users",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/users/{{userId}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/users/users/{{userId}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Properties",
      "item": [
        {
          "name": "Create Property",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/properties",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sunset Apartments\",\n  \"address\": \"123 Sunset Blvd, Los Angeles, CA 90028\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.data?.property?.id) {",
                  "    pm.collectionVariables.set('propertyId', jsonData.data.property.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Properties",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/properties",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Get Property By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/properties/{{propertyId}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Assign Manager to Property",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/properties/{{propertyId}}/assign-manager",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"managerId\": \"{{managerUserId}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Units",
      "item": [
        {
          "name": "Create Unit",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/properties/{{propertyId}}/units",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unitNumber\": \"101\",\n  \"floor\": 1\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.data?.unit?.id) {",
                  "    pm.collectionVariables.set('unitId', jsonData.data.unit.id);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Create Ticket (Tenant)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/tickets",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Leaking faucet in kitchen\",\n  \"description\": \"The kitchen faucet has been leaking for 2 days\",\n  \"priority\": \"MEDIUM\",\n  \"propertyId\": \"{{propertyId}}\",\n  \"unit\": \"101\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.data?.ticket?.id) {",
                  "    pm.collectionVariables.set('ticketId', jsonData.data.ticket.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get My Tickets (Tenant)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/tickets/my",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Get Assigned Tickets (Technician)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/tickets/assigned",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Get All Tickets (Manager)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/tickets",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Get Ticket By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/tickets/{{ticketId}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Assign Ticket (Manager)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/assign",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"technicianId\": \"{{technicianUserId}}\"\n}"
            }
          }
        },
        {
          "name": "Update Ticket (Manager)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/tickets/{{ticketId}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\",\n  \"priority\": \"HIGH\"\n}"
            }
          }
        },
        {
          "name": "Update Ticket Progress (Technician)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/progress",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"DONE\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get My Notifications",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/notifications",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Mark Notification as Read",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/notifications/notification-id/read",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Activity",
      "item": [
        {
          "name": "Get Ticket Activity",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/activity/{{ticketId}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        }
      ]
    }
  ]
}
